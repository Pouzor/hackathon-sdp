# ============================================================
# Backend API
# ============================================================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/planets

# DEBUG=true active /docs, /redoc, /openapi.json — désactiver en production
DEBUG=true

# JWT — générer avec : python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-generate-with-secrets-token-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ============================================================
# Google OAuth 2.0
# Créer les credentials sur : https://console.cloud.google.com/apis/credentials
# URI de redirection autorisée : http://localhost:8000/api/v1/auth/google/callback
# ============================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback
GOOGLE_AUTH_URL=https://accounts.google.com/o/oauth2/v2/auth
GOOGLE_TOKEN_URL=https://oauth2.googleapis.com/token
GOOGLE_USERINFO_URL=https://www.googleapis.com/oauth2/v3/userinfo

# Restreint les connexions au domaine @eleven-labs.com
ALLOWED_DOMAIN=eleven-labs.com

# ============================================================
# CORS — origines autorisées (séparées par des virgules)
# ============================================================
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# URL de redirection frontend après login (côté backend)
FRONTEND_URL=http://localhost:5173

# ============================================================
# Slack Webhooks (optionnel — P2)
# ============================================================
SLACK_WEBHOOK_URL=

# ============================================================
# Client-side (exposé dans le bundle — NE PAS mettre de secrets)
# ============================================================
VITE_API_URL=http://localhost:8000/api/v1
# VITE_GOOGLE_CLIENT_ID n'est pas nécessaire — le flow OAuth est géré côté backend
